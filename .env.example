# Server
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/manriix_rtc

# Cloudinary — sign up free at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Event Config
INSTAGRAM_URL=https://www.instagram.com/manriix_/
STEP1_POINTS=100
STEP2_POINTS=150
STEP4_POINTS=300
POINTS_PER_CAPTURE=15

# Admin dashboard password
ADMIN_SECRET=change_me_before_event

# Email notifications (Gmail with App Password)
# 1. Enable 2FA on your Google account
# 2. myaccount.google.com > Security > App passwords > create one
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
NOTIFY_EMAIL=internal_team@yourcompany.com

# Client origin (for CORS in dev)
CLIENT_URL=http://localhost:5173
